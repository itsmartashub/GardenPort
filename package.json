{
	"name": "gardenport",
	"version": "1.0.0",
	"displayName": "GardenPort - Radio Garden Favorites Backup & Restore",
	"description": "Never lose your Radio Garden station collection again. GardenPort gives you full manual control over your Radio Garden favorites - export, import, merge, or replace your station list with ease.",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/itsmartashub/gardenport.git"
	},
