	},
	"homepage": "https://github.com/itsmartashub/gardenport/",
	"author": "itsmartashub",
	"keywords": [
		"radio-garden",
		"radio-garden-backup",
		"radio-garden-restore",
		"radio-garden-restore-stations",
		"radio-garden-export-stations",
		"radio-garden-import-stations",
		"radio-garden-favorites",
		"radio-garden-favorites-backup",
		"radio-garden-favorites-restore",
		"browser-extension",
		"chrome-extension",
		"firefox-extension",
		"firefox-addon",
		"chrome-web-store",
		"radio-garden",
